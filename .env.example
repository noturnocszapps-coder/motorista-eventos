# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_URL: The base URL of your Supabase Cloud project (PostgreSQL / Auth / Realtime / Storage API)
SUPABASE_URL=https://your-supabase-project.supabase.co

# SUPABASE_ANON_KEY: The public anonymous API key for authenticating requests on the client
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
